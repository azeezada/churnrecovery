# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/app/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/app/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app/dashboard

# Stripe (optional — for webhook handler)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ConvertKit (email drip automation)
# Get API key: ConvertKit dashboard → Account Settings → API → API Key
# Get form ID: Landing Pages & Forms → [your form] → the number in the URL
CONVERTKIT_API_KEY=your_convertkit_api_key_here
CONVERTKIT_FORM_ID=your_convertkit_form_id_here

# Resend (transactional emails — welcome, dunning, etc.)
# Get API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx

# Clerk Webhook Secret (for user.created webhook → welcome email)
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Cloudflare Web Analytics (free, privacy-first analytics)
# Get token: Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site
# For Cloudflare Pages: Workers & Pages → [project] → Metrics → Enable Web Analytics
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=your_cloudflare_beacon_token_here
